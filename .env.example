LLM_PROVIDER=groq
LLM_PROVIDER_PRIORITY=gemini,groq,openai
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.8
LLM_REQUEST_TIMEOUT_SECONDS=90

# Large document performance controls
CHUNK_SUMMARY_TIMEOUT_SECONDS=120

# API safety controls
MAX_CONTENT_LENGTH_BYTES=2097152
MAX_INPUT_CHARS=50000
DEFAULT_RATE_LIMIT=30 per minute
SUMMARIZE_RATE_LIMIT=10 per minute

# OpenAI (paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_MODEL_LEGAL=
OPENAI_MODEL_MEDICAL=
OPENAI_MODEL_FINANCE=

# Groq (free tier available)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_LEGAL=
GROQ_MODEL_MEDICAL=
GROQ_MODEL_FINANCE=

# Gemini (free tier available)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODEL_LEGAL=
GEMINI_MODEL_MEDICAL=
GEMINI_MODEL_FINANCE=

# Optional fallback model for local transformer summarization.
HF_SUMMARIZER_MODEL=facebook/bart-large-cnn
